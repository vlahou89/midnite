    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.4.2",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.15.10",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "start-server-and-test": "^2.0.10",
    "storybook": "^10.4.6",
    "typescript": "~5.7.3",
    "vite": "^6.1.0",
    "vite-plugin-vue-devtools": "^7.7.2",
